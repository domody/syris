{
  "name": "syris",
  "version": "3.0.1",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/*",
    "apps/syris_nutrition/apps/*",
    "core/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
